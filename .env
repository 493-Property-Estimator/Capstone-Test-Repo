# Shared runtime configuration used by frontend and backend.

# API
API_BASE_URL=http://localhost:8000/api/v1
PREFER_LIVE_API=1
ALLOW_MOCK_FALLBACK=0
ALLOW_MOCK_FALLBACK=0

# Search provider mode:
# db   -> database-backed address search
# osrm -> reserved mode; current backend falls back to db until OSRM geocoding is implemented
SEARCH_PROVIDER=db

# Comma-separated list of layers to expose in frontend and backend.
ENABLED_LAYERS=schools,parks,playgrounds,police_stations,municipal_wards,provincial_districts,federal_districts,census_subdivisions,census_boundaries,assessment_zones,assessment_properties
