# Shared runtime configuration used by frontend and backend.

# API
API_BASE_URL=http://localhost:8000/api/v1
PREFER_LIVE_API=1
ALLOW_MOCK_FALLBACK=0

# Search provider mode:
# db   -> database-backed address search
# osrm -> reserved mode; current backend falls back to db until OSRM geocoding is implemented
SEARCH_PROVIDER=db
ESTIMATE_TIME_BUDGET_SECONDS=60
SEARCH_QUERY_MIN_CHARS=3
SEARCH_SUGGESTIONS_DEFAULT_LIMIT=5
SEARCH_SUGGESTIONS_LIMIT_MIN=1
SEARCH_SUGGESTIONS_LIMIT_MAX=10
SEARCH_RESOLVE_MATCH_LIMIT=5

# Property viewport API limits and frontend fetch tuning.
PROPERTIES_DEFAULT_LIMIT=5000
PROPERTIES_LIMIT_MIN=100
PROPERTIES_LIMIT_MAX=10000
PROPERTIES_ZOOM_MIN=0
PROPERTIES_ZOOM_MAX=25
PROPERTIES_CLUSTER_ZOOM_THRESHOLD=17
PROPERTY_LIMIT_DEFAULT=5000
PROPERTY_LIMIT_HIGH_ZOOM=4000
PROPERTY_HIGH_ZOOM_THRESHOLD=17
PROPERTY_PREFETCH_VIEWPORTS=2
PROPERTY_CACHE_TTL_MS=30000

# Frontend UI timing.
LAYERS_REFRESH_DEBOUNCE_MS=300
PROPERTY_REFRESH_DEBOUNCE_MS=180
SEARCH_INPUT_DEBOUNCE_MS=300

# Health/scheduler thresholds.
HEALTH_RATE_LIMIT_WINDOW_SECONDS=60
MEMORY_HIGH_RSS_KB=1200000
REFRESH_SCHEDULE_MIN_SECONDS=30

# Comma-separated list of layers to expose in frontend and backend.
ENABLED_LAYERS=schools,parks,playgrounds,police_stations,transit_stops,businesses,green_space,roads,municipal_wards,provincial_districts,federal_districts,census_subdivisions,census_boundaries,assessment_properties
LAYER_LAB_LAYER_IDS=schools,parks,playgrounds,police_stations,transit_stops,businesses,green_space,roads,municipal_wards,provincial_districts,federal_districts,census_subdivisions,census_boundaries
